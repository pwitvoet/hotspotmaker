<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="350"
        xmlns:linking="using:HotspotMaker.Hotspot.Linking"
        Width="600" Height="350"
        x:Class="HotspotMaker.Hotspot.Linking.MultiLinkWindow"
        x:DataType="linking:MultiLinkWindowVM"
        Title="Create a link for multiple textures">
    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <!-- Binding settings: -->
            <Grid Grid.Column="0" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="5">
                <TextBlock Grid.Row="0" Text="Hotspot link settings:" FontWeight="Bold" Margin="5" />

                <TextBlock Grid.Column="0" Grid.Row="1" Text="Texture name pattern:" Margin="5" VerticalAlignment="Center" />
                <TextBox x:Name="TextureNamePatternTextBox" Grid.Column="1" Grid.Row="1" Text="{Binding TextureNamePattern}" MinWidth="150" Margin="5" VerticalAlignment="Center" />

                <Border Grid.ColumnSpan="2" Grid.Row="2" BorderBrush="#CCC4A5" BorderThickness="1" Background="#FFF6CC" Margin="5">
                    <TextBlock Text="Use wildcards (*) to match multiple texture names at once." Margin="5" />
                </Border>

                <TextBlock Grid.Column="0" Grid.Row="3" Text="Link to hotspot set:" Margin="5" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Grid.Row="3" ItemsSource="{Binding HotspotRectangleSets}" SelectedItem="{Binding SelectedHotspotRectangleSet}"
                            DisplayMemberBinding="{Binding Name}"
                            MinWidth="150" Margin="5" VerticalAlignment="Center" />

                <TextBlock Grid.Column="0" Grid.Row="4" Text="New rectangle set name:" Margin="5" VerticalAlignment="Center"
                           IsVisible="{Binding IsNewHotspotRectangleSet}" />
                <TextBox Grid.Column="1" Grid.Row="4" Text="{Binding NewHotspotRectangleSetName}" MinWidth="150" Margin="5" VerticalAlignment="Center"
                            IsVisible="{Binding IsNewHotspotRectangleSet}" />

                <TextBlock Grid.Column="0" Grid.Row="5" Text="Fallback texture name pattern:" Margin="5" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Grid.Row="5" Text="{Binding FallbackTextureNamePattern}" MinWidth="150" Margin="5" VerticalAlignment="Center" />

                <Border Grid.ColumnSpan="2" Grid.Row="6" BorderBrush="#CCC4A5" BorderThickness="1" Background="#FFF6CC" Margin="5">
                    <TextBlock Text="Use placeholders ({0}) to reference wildcard parts." Margin="5" />
                </Border>
            </Grid>

            <!-- Affected textures list: -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="5">
                <TextBlock Grid.Row="0" Text="Affected textures:" FontWeight="Bold" Margin="5" />
                <ListBox Grid.Row="1" ItemsSource="{Binding AffectedTextureNames}" MinWidth="200" VerticalAlignment="Stretch" Margin="5" />
            </Grid>
        </Grid>

        <Border Grid.Row="1" Background="#D0D0D0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OkButton" Content="Ok" Click="OkButton_Click" IsEnabled="{Binding !HasErrors}" Padding="10,2" Margin="5" />
                <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Padding="10,2" Margin="5" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
